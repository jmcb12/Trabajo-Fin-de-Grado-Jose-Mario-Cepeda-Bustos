<?xml version='1.0' encoding='utf-8'?>
<widget id="io.cordova.hellocordova" version="1.0.0" xmlns="http://www.w3.org/ns/widgets"
    xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>SpeakMe Paciente</name>
    <description> Aplicación móvil del paciente para SpeakMe Rehab.</description>
    <author email="jmariocepedabus@gmail.com" href="https://localhost">
        Jose Mario Cepeda Bustos
    </author>
    <content src="index.html" />

    <access origin="*" />
    <allow-navigation href="*" />

    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />

    <platform name="android">
        <preference name="AndroidInsecureFileModeEnabled" value="true" />
    </platform>

</widget>